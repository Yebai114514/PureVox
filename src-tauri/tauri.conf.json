{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PureVox",
  "version": "0.1.0",
  "identifier": "com.purevox.player",
  "build": {
    "frontendDist": "../src-frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "..\\scripts\\dev-frontend.bat",
    "beforeBuildCommand": "cd /d D:\\Rust_Projects\\PureVox\\src-frontend && node node_modules/vite/bin/vite.js build"
  },
  "app": {
    "windows": [
      {
        "title": "PureVox",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#0a0a0f",
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
